{
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": {
                    "type": "grafana",
                    "uid": "-- Grafana --"
                },
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "datasource": {
                "type": "loki",
                "uid": "${datasource}"
            },
            "gridPos": {
                "h": 17,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": true,
                "showCommonLabels": false,
                "showLabels": false,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": false
            },
            "pluginVersion": "10.0.0",
            "targets": [
                {
                    "editorMode": "code",
                    "expr": "{service=~\"api|worker\"} | json | requestId=\"$requestId\"",
                    "queryType": "range",
                    "refId": "A"
                }
            ],
            "title": "Trace Logs (Filtered by Request ID)",
            "type": "logs"
        },
        {
            "datasource": {
                "type": "loki",
                "uid": "${datasource}"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 17
            },
            "id": 2,
            "options": {
                "showTypeIcons": true
            },
            "targets": [
                {
                    "editorMode": "code",
                    "expr": "sum(count_over_time({service=\"worker\"} | json | event=\"ENCODE_FAILED\" [$__interval])) by (error)",
                    "legendFormat": "{{error}}",
                    "refId": "A"
                }
            ],
            "title": "Failed Jobs by Error",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "loki",
                "uid": "${datasource}"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 17
            },
            "id": 3,
            "targets": [
                {
                    "editorMode": "code",
                    "expr": "{service=\"worker\"} | json | event=\"ENCODE_READY\"",
                    "refId": "A"
                }
            ],
            "title": "Completed Jobs",
            "type": "logs"
        }
    ],
    "refresh": "5s",
    "schemaVersion": 38,
    "style": "dark",
    "tags": [
        "netflop",
        "pipeline"
    ],
    "templating": {
        "list": [
            {
                "current": {
                    "selected": false,
                    "text": "Loki",
