# ═══════════════════════════════════════════════════════════════
# Netflop Staging Environment
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.staging and modify values as needed
# DO NOT COMMIT REAL SECRETS

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
POSTGRES_DB=netflop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=staging_password_change_me

# ─────────────────────────────────────────────────────────────
# MinIO (S3-compatible storage)
# ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=staging_minio_password
S3_BUCKET=netflop-media
S3_PRESIGN_BASE_URL=http://localhost:9000

# ─────────────────────────────────────────────────────────────
# JWT Secrets (CHANGE THESE!)
# ─────────────────────────────────────────────────────────────
JWT_SECRET=staging_jwt_secret_change_this_to_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=staging_refresh_secret_change_this_too
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# CORS (add your staging domain if needed)
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:19006,http://localhost:8081
