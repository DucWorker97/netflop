# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/netflop

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_too_another_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# Object Storage (MinIO / S3)
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_PRESIGN_BASE_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=netflop-media
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000/netflop-media

# ─────────────────────────────────────────────────────────────
# Upload / Stream
# ─────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=2048
UPLOAD_PRESIGNED_TTL_SECONDS=3600
STREAM_URL_TTL_SECONDS=3600

# ─────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:19006,http://localhost:8081

# ─────────────────────────────────────────────────────────────
# Admin Web (Next.js)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_S3_PUBLIC_BASE_URL=http://localhost:9000/netflop-media

# ─────────────────────────────────────────────────────────────
# Mobile (Expo)
# For physical device, replace localhost with your machine's LAN IP
# For Android emulator, use 10.0.2.2 instead of localhost
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# AI Curator (Python Recommendation Service)
# ─────────────────────────────────────────────────────────────
AI_CURATOR_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# Gemma LLM (Google AI Studio - FREE)
# Get your key at: https://aistudio.google.com/apikey
# ─────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=CHANGE_ME

# ─────────────────────────────────────────────────────────────
# ClickHouse (Analytics)
# ─────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=netflop_analytics

# ─────────────────────────────────────────────────────────────
# CAPTCHA (disabled by default)
# Provider: none | recaptcha_v2 | recaptcha_v3 | turnstile
# ─────────────────────────────────────────────────────────────
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=none
# CAPTCHA_SITE_KEY=
# CAPTCHA_SECRET_KEY=

# ─────────────────────────────────────────────────────────────
# Mail (disabled by default)
# Provider: none | smtp
# ─────────────────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@netflop.dev
MAIL_HOST=smtp.example.com
MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
