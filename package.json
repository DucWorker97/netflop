{
    "name": "netflop",
    "version": "0.0.1",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "clean": "turbo run clean && rm -rf node_modules",
        "verify": "bash scripts/ci/verify.sh",
        "smoke": "bash scripts/ci/smoke.sh",
        "smoke:video": "bash scripts/ci/video-pipeline-smoke.sh",
        "infra:up": "docker compose up -d",
        "infra:down": "docker compose down",
        "infra:logs": "docker compose logs -f",
        "infra:reset": "docker compose down -v && docker compose up -d",
        "db:generate": "pnpm --filter @netflop/api prisma generate",
        "db:migrate": "pnpm --filter @netflop/api prisma migrate dev",
        "db:migrate:deploy": "pnpm --filter @netflop/api prisma migrate deploy",
        "db:seed": "pnpm --filter @netflop/api prisma db seed",
        "db:studio": "pnpm --filter @netflop/api prisma studio",
        "db:reset": "pnpm --filter @netflop/api prisma migrate reset --force",
        "smoke:health": "curl -s http://localhost:3000/health | jq .",
        "release:check": "pnpm lint && pnpm typecheck && pnpm build && pnpm smoke:video && echo '✅ RELEASE CHECK PASSED'",
        "demo:prep": "pnpm infra:up && pnpm db:migrate:deploy && pnpm db:seed && echo '✅ DEMO PREP COMPLETE'",
        "deploy:staging": "docker compose -f deploy/docker-compose.staging.yml --env-file deploy/.env.staging up -d --build",
        "deploy:staging:down": "docker compose -f deploy/docker-compose.staging.yml down",
        "deploy:staging:logs": "docker compose -f deploy/docker-compose.staging.yml logs -f",
        "dev:core": "turbo run dev --filter=@netflop/api --filter=@netflop/worker --filter=@netflop/admin --filter=@netflop/web --filter=@netflop/mobile",
        "dev:web": "node scripts/use-env.js .env.web.local && pnpm dev:core",
        "dev:mobile:emu": "node scripts/use-env.js .env.mobile.emu && pnpm dev:core",
        "dev:lan": "node scripts/use-env.js .env.lan.local && pnpm dev:core",
        "kill:ports": "npx kill-port 3000 8081 9000 || true",
        "mobile:start": "pnpm --filter @netflop/mobile start",
        "mobile:fix": "cd apps/mobile && npx expo install --fix",
        "check:mojibake": "node scripts/check-mojibake.js",
        "fix:mojibake": "node scripts/fix-mojibake.js"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "turbo": "^2.3.0",
        "typescript": "^5.7.0",
        "prettier": "^3.4.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.0"
    }
}
