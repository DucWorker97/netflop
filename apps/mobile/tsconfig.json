{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "expo-router": [
        "./src/types/expo-router"
      ],
      "react-native-reanimated": [
        "./src/types/react-native-reanimated"
      ],
      "expo-av": [
        "./src/types/expo-av"
      ],
      "expo-blur": [
        "./src/types/expo-blur"
      ],
      "expo-linear-gradient": [
        "./src/types/expo-linear-gradient"
      ],
      "@expo/vector-icons": [
        "./src/types/expo-vector-icons"
      ]
    },
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ],
  "extends": "expo/tsconfig.base"
}
